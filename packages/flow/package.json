{
  "name": "@retry-labs/flow",
  "version": "0.1.0",
  "description": "A versatile diagramming library for system architecture and flow diagrams. Zero-dependency, works in React, Vue, Angular, or plain HTML.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/flow.standalone.js",
  "jsdelivr": "./dist/flow.standalone.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./vue": {
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.cjs",
      "types": "./dist/wrappers/vue.d.ts",
      "default": "./dist/vue.mjs"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/retry-labs/flow.git",
    "directory": "packages/flow"
  },
  "homepage": "https://retry-labs.github.io/flow/",
  "bugs": {
    "url": "https://github.com/retry-labs/flow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:types",
    "build:lib": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:watch": "rollup -c -w",
    "stage:site": "mkdir -p ../../website/dist && cp dist/flow.standalone.js ../../website/dist/",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node scripts/smoke-test.cjs",
    "test:anchor": "node scripts/anchor-test.cjs",
    "test:dsl": "node scripts/dsl-test.cjs",
    "test:showcase": "node scripts/showcase-test.cjs",
    "test:viewport": "node scripts/viewport-test.cjs",
    "test:mount": "node scripts/mount-e2e.cjs",
    "test:player": "node scripts/player-test.cjs",
    "test:react": "node scripts/react-wrapper-test.cjs",
    "test:vue": "node scripts/vue-wrapper-test.cjs",
    "test:features": "node scripts/features-test.cjs",
    "test": "npm run test:smoke && npm run test:anchor && npm run test:dsl && npm run test:showcase && npm run test:viewport && npm run test:mount && npm run test:player && npm run test:features && npm run test:react && npm run test:vue"
  },
  "keywords": [
    "diagram",
    "flowchart",
    "architecture",
    "system-design",
    "svg",
    "visualization",
    "react",
    "vue",
    "angular",
    "web-component",
    "docusaurus",
    "confluence",
    "isometric",
    "blueprint",
    "dsl",
    "no-dependency"
  ],
  "author": "Retry Labs",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vue": "^3.4.0",
    "rollup": "^4.9.6",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
